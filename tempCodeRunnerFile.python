def valid_permutations(input1):
    count = 0
    visited = [False] * (input1 + 1)

    def backtrack(pos):
        nonlocal count
        if pos > input1:
            count += 1
            return

        for i in range(1, input1 + 1):
            if not visited[i]:
                if i % pos == 0 or pos % i == 0:
                    visited[i] = True
                    backtrack(pos + 1)
                    visited[i] = False

    backtrack(1)
    return count